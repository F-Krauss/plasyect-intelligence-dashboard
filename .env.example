# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Frontend: Hostinger build points here.
VITE_API_BASE_URL="https://plasyect-api-wjttlfxvua-uc.a.run.app"

# Backend API.
PORT="8080"
JWT_SECRET="change-me-long-random-string"
CORS_ORIGINS="*"

# Tarjetas viajeras reales (BixApp). El backend lee las tablas bigzap_* que
# llena el sync-service. Tenant al que se asignan los lotes/pedidos reales:
DEFAULT_TENANT_ID="plasyect_matriz"
# Maximo de tarjetas viajeras activas que carga el dashboard y ventana (dias)
# para seguir mostrando lotes ya facturados como recientes.
BIGZAP_BATCH_LIMIT="800"
BIGZAP_ACTIVE_DAYS="30"

# Supabase. El backend se conecta por Postgres DIRECTO (mismo credential que el
# sync-service); es la via preferida y no requiere la service_role key.
# Usar el "Transaction pooler" (puerto 6543) para Cloud Run.
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres"
PGSSL="true"

# Alternativa (no usada por defecto): Supabase REST con service_role.
# SUPABASE_URL="https://PROJECT_REF.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_ACCESS_TOKEN="SUPABASE_MANAGEMENT_PAT"
SUPABASE_ORG_SLUG="your-org-slug"
SUPABASE_DB_PASSWORD="change-me-db-password"
SUPABASE_PROJECT_NAME="dashboard-plasyect"
SUPABASE_REGION="us-east-2"

# Google Cloud.
GCP_PROJECT_ID="dashboard-plasyect"
GCP_BILLING_ACCOUNT="0161CF-D9430E-EA40FB"
GCP_REGION="us-central1"
DOCUMENT_AI_LOCATION="us"
DOCUMENT_AI_PROCESSOR_ID=""

# Big Zap / Firebird: la conexion vive en el servicio que corre junto al ERP.
# Ver sync-service/.env.example (FIREBIRD_*, DATABASE_URL) y docs/bigzap-fdb-schema.md.
