# --- Firebird (BixApp / BIGZAP.FDB en el Windows Server) ---
# El servicio corre en el mismo servidor, por eso localhost.
FIREBIRD_HOST="127.0.0.1"
FIREBIRD_PORT="3050"
# Ruta COMO LA VE EL SERVIDOR FIREBIRD (ruta local del servidor o alias de databases.conf)
FIREBIRD_DATABASE="C:\\BigZap\\BIGZAP.FDB"
FIREBIRD_USER="SYSDBA"
FIREBIRD_PASSWORD="masterkey"

# --- PostgreSQL destino (Supabase) ---
# Usar el "Session pooler" URI del proyecto Supabase (puerto 5432) o conexion directa.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-2.pooler.supabase.com:5432/postgres"
# "false" solo para Postgres local de pruebas sin TLS
PGSSL="true"

# --- Comportamiento ---
# Cada cuantos SEGUNDOS se busca novedad (ademas del watcher de archivo).
# 15 = cada 15 s · 300 = 5 min · 900 = 15 min · 3600 = 1 hora
SYNC_INTERVAL_SECONDS="900"
# Dias de traslape al consultar por fecha (re-lee y re-upserta, es idempotente)
SYNC_OVERLAP_DAYS="2"
# Hora local (0-23) del refresco completo diario; vacio = nunca
FULL_RESYNC_HOUR="3"
# Zona horaria de la planta para convertir AV_FECHA + AV_HORA a timestamp
PLANT_TZ="America/Mexico_City"
# Opcional: ruta local del archivo FDB para detectar escrituras al instante (mtime).
# Solo lectura de metadatos; NO abre el archivo.
FDB_WATCH_PATH="C:\\BigZap\\BIGZAP.FDB"
