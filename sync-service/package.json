{
  "name": "plasyect-bigzap-sync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Sincroniza tarjetas viajeras de Bigzap (Firebird BIGZAP.FDB) hacia PostgreSQL/Supabase.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:once": "tsx src/index.ts --once",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:once": "node dist/index.js --once",
    "migrate": "tsx scripts/apply-migrations.ts",
    "test:connection": "tsx scripts/test-connection.ts",
    "test": "node --test --import tsx src/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "node-firebird": "^1.1.9",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
